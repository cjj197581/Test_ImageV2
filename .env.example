# ChatGPT Images 2.0 (gpt-image-2) 配置

# API易 (apiyi.com) API Key
API_KEY=your-api-key-here

# API易 国内主力节点
# OpenAI 兼容模型:   https://api.apiyi.com/v1
# 官逆/vip 模型也可用: https://vip.apiyi.com/v1
BASE_URL=https://api.apiyi.com/v1

# ═══════════════════════════════════════════════════════════════════════════
# 可用模型:
#   gpt-image-2     官方直连, token计费, 支持 quality/4K/mask
#   gpt-image-2-all 官逆通道, $0.03/张统一价, 30-60s 快速
#   gpt-image-2-vip 官逆Codex通道, $0.03/张统一价, 90-150s
#
# 画质 (仅官方模型):
#   low    3-8s,   $0.006  — 缩略图/原型
#   medium 25-40s, $0.053  — 电商/社媒
#   high   200s+,  $0.211  — 海报/印刷/文字密集
#   auto   自动选择 (默认)
#
# 输出格式: png (默认) / jpeg / webp
# 尺寸约束: 边长 ≤3840, 16的倍数, 宽高比 ≤3:1
# ═══════════════════════════════════════════════════════════════════════════
